# Copy sang .env và chỉnh cho môi trường local.
APP_ENV=development
PORT=8080

# Khớp với docker-compose.yml (user/pass/db mặc định = blog)
DATABASE_URL=postgres://blog:blog@localhost:5432/blog?sslmode=disable

# --- Auth Google OAuth (Slice 2) ---
# Tạo OAuth client ở Google Cloud Console (Web application), redirect URI khớp bên dưới.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Redirect về đây sau khi đăng nhập thành công (dev: admin SPA Vite).
APP_BASE_URL=http://localhost:5173

# CSV email admin được phép đăng nhập (rỗng = không ai vào được).
ADMIN_ALLOWLIST=

# CSV origin admin SPA được phép gọi API kèm cookie (CORS). Dev: Vite :5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookie session: lax|none|strict. Dùng none (kèm secure=true) khi admin & core khác domain gốc.
SESSION_COOKIE_SAMESITE=lax
# true bắt buộc HTTPS. Mặc định true ở production, false ở dev.
SESSION_COOKIE_SECURE=false

# --- Object storage (S3-compatible). QUY ƯỚC: DEV = MinIO (mặc định), PROD = Cloudflare R2. ---
# DEV: các giá trị dưới khớp docker-compose (MinIO). Không cần đổi gì.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=blog-media
STORAGE_PUBLIC_URL=http://localhost:9000/blog-media
STORAGE_USE_PATH_STYLE=true   # path-style (đúng cho MinIO; R2 cũng chạy với true)
# Thời hạn presigned URL upload (Go duration). Mặc định 15m.
STORAGE_PRESIGN_EXPIRES=15m
#
# PROD (Cloudflare R2) — set STORAGE_* qua env thật của nền tảng deploy (KHÔNG commit secret):
#   STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   STORAGE_ACCESS_KEY=<R2 Access Key ID>       STORAGE_SECRET_KEY=<R2 Secret Access Key>
#   STORAGE_BUCKET=blog-media                     STORAGE_PUBLIC_URL=https://cdn.tenban.com (hoặc pub-xxxx.r2.dev)
#   STORAGE_USE_PATH_STYLE=true
# Nhớ đặt CORS trên bucket R2 (cho origin admin PUT trực tiếp). Chi tiết: README "Object storage".

# Giới hạn body request (bytes). Mặc định 2097152 (2 MiB).
# MAX_BODY_BYTES=2097152

# ── Observability & workers (Slice 9) ─────────────────────────────
# Mức log: debug | info | warn | error (mặc định info)
LOG_LEVEL=info
# Cổng metrics server riêng (/metrics + pprof) — KHÔNG public ra internet
METRICS_PORT=9091
# Bật /debug/pprof trên metrics server (mặc định: bật ngoài production)
#PPROF_ENABLED=true
# Redis cache (rỗng/không set = cache tắt, dev không bắt buộc)
#REDIS_URL=redis://localhost:6379/0
# View counter: chu kỳ flush + kích thước buffer channel
VIEW_FLUSH_INTERVAL=5s
VIEW_BUFFER_SIZE=1024
# Blurhash worker: số goroutine, giới hạn size ảnh, timeout tải
BLURHASH_WORKERS=3
BLURHASH_MAX_BYTES=10485760
BLURHASH_FETCH_TIMEOUT=10s
# SSRF guard: host được phép tải ảnh NGOÀI host storage (CSV). Host lạ khác
# chỉ được phép nếu resolve ra IP công khai. Dev seed dùng picsum:
BLURHASH_ALLOWED_HOSTS=picsum.photos,fastly.picsum.photos

# ── Reader auth & view dedupe (Slice 13) ──────────────────────────
# Reader auth (Slice 13) — OAuth người đọc, callback riêng khỏi admin
READER_REDIRECT_URL=http://localhost:8080/auth/reader/google/callback
# Base URL web công khai để redirect reader về sau khi login
WEB_BASE_URL=http://localhost:3000
# Salt hash IP cho view dedupe (bắt buộc khi bật REDIS_URL)
VIEW_DEDUP_SALT=doi-gia-tri-ngau-nhien-dai
# CORS: thêm origin web công khai (ngoài admin) — CSV
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
