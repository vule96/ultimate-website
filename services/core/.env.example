# Copy sang .env và chỉnh cho môi trường local.
APP_ENV=development
PORT=8080

# Khớp với docker-compose.yml (user/pass/db mặc định = blog)
DATABASE_URL=postgres://blog:blog@localhost:5432/blog?sslmode=disable

# --- Auth Google OAuth (Slice 2) ---
# Tạo OAuth client ở Google Cloud Console (Web application), redirect URI khớp bên dưới.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Redirect về đây sau khi đăng nhập thành công (dev: admin SPA Vite).
APP_BASE_URL=http://localhost:5173

# CSV email admin được phép đăng nhập (rỗng = không ai vào được).
ADMIN_ALLOWLIST=

# CSV origin admin SPA được phép gọi API kèm cookie (CORS). Dev: Vite :5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookie session: lax|none|strict. Dùng none (kèm secure=true) khi admin & core khác domain gốc.
SESSION_COOKIE_SAMESITE=lax
# true bắt buộc HTTPS. Mặc định true ở production, false ở dev.
SESSION_COOKIE_SECURE=false
