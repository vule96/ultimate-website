# Copy → .env.prod (GITIGNORED — chứa secret thật, tuyệt đối không commit).
# docker-compose.prod.yml đọc file này qua env_file + biến interpolation.

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=blog
POSTGRES_PASSWORD=doi-mat-khau-nay
POSTGRES_DB=blog

# ── Core (bổ sung DATABASE_URL/REDIS_URL do compose tự set) ────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://api.example.com/auth/google/callback
ADMIN_ALLOWLIST=you@example.com
APP_BASE_URL=https://admin.example.com
CORS_ALLOWED_ORIGINS=https://admin.example.com
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true

# Storage R2 (production)
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=ultimate-media
STORAGE_PUBLIC_URL=https://media.example.com
STORAGE_USE_PATH_STYLE=false

# Observability
LOG_LEVEL=info
METRICS_PORT=9091
PPROF_ENABLED=false
BLURHASH_ALLOWED_HOSTS=

# ── Web / Admin build args ─────────────────────────────────────────
NEXT_PUBLIC_MEDIA_HOST=media.example.com
ADMIN_API_URL=https://api.example.com
GRAFANA_ADMIN_PASSWORD=doi-mat-khau-grafana
GIT_SHA=dev

# ── Production edge — Caddy reverse-proxy + auto-TLS (Slice 16) ─────
# Domains trỏ về server (DNS Cloudflare). Local test: để trống → *.localhost + self-signed.
WEB_DOMAIN=example.com
API_DOMAIN=api.example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=admin@example.com
# internal = self-signed (test) | email@domain = ACME thật.
TLS_MODE=internal
# DNS-01 (khuyên khi sau Cloudflare proxy): token Cloudflare có quyền Zone:DNS:Edit,
# rồi bỏ comment `acme_dns` trong Caddyfile + đặt TLS_MODE=email.
CLOUDFLARE_API_TOKEN=

# ── DB backup → R2 (dùng lại STORAGE_* creds, bucket riêng) ─────────
BACKUP_BUCKET=ultimate-backups
BACKUP_KEEP=14
